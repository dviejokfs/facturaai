{
  "name": "invoscanai",
  "version": "1.0.0",
  "private": true,
  "description": "InvoScanAI monorepo — AI-powered financial autopilot for Spanish autónomos",
  "workspaces": ["apps/*", "marketing/ads"],
  "scripts": {
    "dev": "bun --cwd apps/backend run dev",
    "backend:dev": "bun --cwd apps/backend run dev",
    "backend:migrate": "bun --cwd apps/backend run db:migrate",
    "web:dev": "bun --cwd apps/web run dev"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "jsonwebtoken": "^9.0.3"
  }
}
