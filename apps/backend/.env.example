# Server
PORT=3000
NODE_ENV=development
PUBLIC_URL=http://localhost:3000

# Postgres (Bun.sql)
POSTGRES_URL=postgres://postgres:password@localhost:5432/invoscanai

# JWT signing (generate with: openssl rand -base64 48)
JWT_SECRET=change-me-in-production-please-use-a-strong-random-secret

# Google OAuth 2.0
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# iOS custom URL scheme for auth return
IOS_REDIRECT_SCHEME=invoscanai://auth

# AI Gateway (OpenAI-compatible — Temps AI Gateway or direct provider)
AI_GATEWAY_URL=https://app.temps.kfs.es/api/ai/v1
AI_API_KEY=your-api-key
AI_MODEL=claude-sonnet-4-6

# S3 / R2 storage
S3_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=invoscanai-invoices
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# RevenueCat (https://app.revenuecat.com → Project Settings → API Keys)
REVENUECAT_PUBLIC_SDK_KEY_IOS=
REVENUECAT_SECRET_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_PROJECT_ID=
