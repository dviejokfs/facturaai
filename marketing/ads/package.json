{
  "name": "@facturaai/ads",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FacturaAI ad generation pipeline — country-first, spec-driven, Remotion-rendered",
  "scripts": {
    "ads": "bun run src/cli.ts",
    "scripts": "bun run src/cli.ts scripts",
    "build": "bun run src/cli.ts build",
    "generate": "bun run src/cli.ts generate",
    "render:preview": "remotion preview src/remotion/Root.tsx",
    "render:still": "remotion render src/remotion/Root.tsx AdComposition out/preview.mp4",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@remotion/bundler": "^4.0.250",
    "@remotion/cli": "^4.0.250",
    "@remotion/renderer": "^4.0.250",
    "remotion": "^4.0.250",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
